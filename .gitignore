.DS_Store

# Local secrets / credentials — NEVER commit
.env
.env.*
!.env.example
!.env.production.example
!frontend/.env.production.example

# Python
.venv/
venv/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/

# Frontend dependencies and build output
frontend/node_modules/
frontend/dist/

# Runtime data (incl. user credentials, API keys, profiles, vector DB)
logs/
*.log
db/
data/users/

# Large binaries
rag-deploy.tar.gz
*.bak

# Temp / test artifacts
_test_*
_query*

# Thesis / private — never commit
_docwork/
assets/
outputs/
论文插图_drawio/

# Keep small demo markdown files, but avoid committing large/licensed PDFs.
data/raw/*.pdf
data/raw/.DS_Store
